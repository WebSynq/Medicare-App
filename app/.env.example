# Backend API base URL — the FastAPI service on Render.
# Production / staging both point at the same host today; switch
# this when a separate staging API lands.
#
# Anything prefixed NEXT_PUBLIC_* is shipped to the browser bundle.
# Anything NOT prefixed is server-only (App Router server components,
# route handlers). Keep secrets unprefixed.
NEXT_PUBLIC_BACKEND_URL=https://api.ghwcrm.com
